<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceStrong}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="HeadlineLabel" TargetType="Label">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SectionTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="SectionSubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="RequiredAsteriskLabel" TargetType="Label">
        <Setter Property="Text" Value="*" />
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="3,0,0,0" />
    </Style>

    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceStrong}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="ModalCardFrame" TargetType="Frame" BasedOn="{StaticResource CardFrame}">
        <Setter Property="MaximumWidthRequest" Value="440" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="Margin" Value="18" />
    </Style>

    <Style x:Key="BadgeFrame" TargetType="Frame">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Padding" Value="18,0" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

    <Style x:Key="PrimaryAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceStrong}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="SoftButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSubtle}" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSubtle}" />
        <Setter Property="AutoSize" Value="TextChanges" />
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="MinimumHeightRequest" Value="100" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextSubtle}" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>
</ResourceDictionary>
