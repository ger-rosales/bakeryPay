<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BakeryPay.Mobile.Views.ChangePasswordPage"
             Title="Cambiar clave">
    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,34" Spacing="18">
            <Frame Style="{StaticResource CardFrame}"
                   Padding="22">
                <VerticalStackLayout Spacing="18">
                    <Image Source="panaderia_mary_logo.png"
                           HeightRequest="110"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />
                    <Label Text="Actualiza tu clave temporal"
                           Style="{StaticResource HeadlineLabel}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Antes de continuar debes reemplazar la clave entregada por la panificadora con una nueva clave segura."
                           Style="{StaticResource SectionSubtitleLabel}"
                           HorizontalTextAlignment="Center" />

                    <VerticalStackLayout Spacing="14">
                        <Entry Placeholder="Clave actual" IsPassword="True" Text="{Binding CurrentPassword}" />
                        <Entry Placeholder="Nueva clave" IsPassword="True" Text="{Binding NewPassword}" />
                        <Entry Placeholder="Confirmar nueva clave" IsPassword="True" Text="{Binding ConfirmNewPassword}" />
                        <Button Text="Actualizar clave"
                                Style="{StaticResource PrimaryAccentButtonStyle}"
                                Command="{Binding ChangePasswordCommand}" />
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                        <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
