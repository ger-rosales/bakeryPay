<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BakeryPay.Mobile.Views.ProvidersPage"
             Title="Plataforma de Pagos">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,34" Spacing="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Proveedores" Style="{StaticResource SectionTitleLabel}" />
                        <Label Text="Administra proveedores, contactos y credenciales de acceso."
                               Style="{StaticResource SectionSubtitleLabel}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="+ Crear"
                            Style="{StaticResource PrimaryAccentButtonStyle}"
                            IsVisible="{Binding CanManageProviders}"
                            Command="{Binding OpenCreateModalCommand}" />
                </Grid>

                <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                <Label Text="{Binding LastCredentials}" TextColor="{StaticResource Success}" LineBreakMode="WordWrap" />

                <CollectionView ItemsSource="{Binding Providers}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardFrame}">
                                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="14">
                                    <Frame Style="{StaticResource BadgeFrame}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                                        <Label Text="{Binding Initials}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding BusinessName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Code}" TextColor="{StaticResource TextMuted}" />
                                        <Label Text="{Binding ContactName}" TextColor="{StaticResource TextMuted}" />
                                        <Label Text="{Binding UserEmail}" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="End">
                                        <ImageButton Source="icon_edit.png"
                                                     BackgroundColor="Transparent"
                                                     HeightRequest="28"
                                                     WidthRequest="28"
                                                     HorizontalOptions="End"
                                                     IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CanManageProviders}"
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenProviderEditModalCommand}"
                                                     CommandParameter="{Binding .}" />
                                        <Label Text="{Binding TaxId}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                        <Label Text="{Binding Phone}" TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsCreateModalVisible}"
              Padding="18">
            <Frame Style="{StaticResource ModalCardFrame}"
                   VerticalOptions="Center">
                <ScrollView>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding FormTitle}" FontSize="24" FontAttributes="Bold" />
                                <Label Text="{Binding FormDescription}"
                                       Style="{StaticResource SectionSubtitleLabel}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="X"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    Padding="0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding CloseCreateModalCommand}" />
                        </Grid>

                        <Frame Style="{StaticResource CardFrame}"
                               Padding="12"
                               Margin="0"
                               IsVisible="{Binding IsEditMode}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Proveedor seleccionado" FontAttributes="Bold" />
                                <Label Text="{Binding SelectedProviderSummary}" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Frame>

                        <HorizontalStackLayout Spacing="0"
                                               IsVisible="{Binding IsCreateMode}">
                            <Label Text="Codigo" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="PRV-003"
                               Text="{Binding Code}"
                               IsVisible="{Binding IsCreateMode}" />

                        <HorizontalStackLayout Spacing="0"
                                               IsVisible="{Binding IsCreateMode}">
                            <Label Text="Razon social" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="Nombre del proveedor"
                               Text="{Binding BusinessName}"
                               IsVisible="{Binding IsCreateMode}" />

                        <HorizontalStackLayout Spacing="0">
                            <Label Text="RUC" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="0999999999003" Keyboard="Numeric" Text="{Binding TaxId}" />

                        <HorizontalStackLayout Spacing="0">
                            <Label Text="Nombres del contacto" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="Nombres" Text="{Binding ContactFirstName}" />

                        <HorizontalStackLayout Spacing="0">
                            <Label Text="Apellidos del contacto" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="Apellidos" Text="{Binding ContactLastName}" />

                        <HorizontalStackLayout Spacing="0"
                                               IsVisible="{Binding IsCreateMode}">
                            <Label Text="Identificacion del contacto" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="Cedula o identificacion"
                               Text="{Binding ContactIdentificationNumber}"
                               IsVisible="{Binding IsCreateMode}" />

                        <HorizontalStackLayout Spacing="0">
                            <Label Text="Correo del contacto" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="correo@proveedor.com" Keyboard="Email" Text="{Binding ContactEmail}" />

                        <Label Text="Telefono del contacto" FontAttributes="Bold" />
                        <Entry Placeholder="0991234567" Keyboard="Telephone" Text="{Binding ContactPhone}" />

                        <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                        <Label Text="* Campo obligatorio"
                               FontSize="12"
                               TextColor="{StaticResource Danger}" />

                        <Button Text="Crear proveedor"
                                Style="{StaticResource PrimaryAccentButtonStyle}"
                                Command="{Binding CreateProviderCommand}"
                                IsVisible="{Binding IsCreateMode}" />
                        <Button Text="Guardar cambios"
                                Style="{StaticResource PrimaryAccentButtonStyle}"
                                Command="{Binding UpdateProviderCommand}"
                                IsVisible="{Binding IsEditMode}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
