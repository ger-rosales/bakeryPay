<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BakeryPay.Mobile.Views.LoginPage"
             Title="Ingreso">
    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,34" Spacing="18" VerticalOptions="Center">
            <Frame Style="{StaticResource CardFrame}"
                   Padding="22"
                   Margin="0,12,0,0">
                <VerticalStackLayout Spacing="18">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Frame BackgroundColor="{StaticResource Accent}"
                               CornerRadius="28"
                               Padding="12"
                               HasShadow="False"
                               HorizontalOptions="Center">
                            <Image Source="login_logo.png"
                                   HeightRequest="136"
                                   WidthRequest="136"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center" />
                        </Frame>
                        <Label Text="Plataforma de Pagos"
                               Style="{StaticResource HeadlineLabel}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Ingresa con tu correo o usa autenticacion biometrica."
                               Style="{StaticResource SectionSubtitleLabel}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="0">
                            <Label Text="Correo electronico" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="tu@email.com"
                               Keyboard="Email"
                               Text="{Binding Email}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="0">
                            <Label Text="Contrasena" FontAttributes="Bold" />
                            <Label Style="{StaticResource RequiredAsteriskLabel}" />
                        </HorizontalStackLayout>
                        <Entry Placeholder="********"
                               IsPassword="True"
                               Text="{Binding Password}" />
                    </VerticalStackLayout>

                    <Button Text="Iniciar sesion"
                            Command="{Binding LoginCommand}" />

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource Border}"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="O CONTINUA CON"
                               TextColor="{StaticResource TextSubtle}"
                               FontSize="12" />
                        <BoxView Grid.Column="2"
                                 HeightRequest="1"
                                 BackgroundColor="{StaticResource Border}"
                                 VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Autenticacion biometrica"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BiometricLoginCommand}" />

                    <Button Text="Registrarme como cajera"
                            Style="{StaticResource SoftButtonStyle}"
                            Command="{Binding OpenCashierRegistrationCommand}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}" Padding="16">
                <HorizontalStackLayout Spacing="10">
                    <Frame Style="{StaticResource BadgeFrame}"
                           HeightRequest="28"
                           WidthRequest="28"
                           CornerRadius="14"
                           Padding="0"
                           VerticalOptions="Center">
                        <Label Text="OK"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryDark}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Frame>
                    <Label Text="Acceso seguro para personal y proveedores."
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
