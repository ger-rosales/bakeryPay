<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BakeryPay.Mobile.Views.RegisterCashierPage"
             Title="Registro de cajera">
    <ScrollView>
        <VerticalStackLayout Padding="20,26,20,34" Spacing="18">
            <Frame Style="{StaticResource CardFrame}"
                   Padding="22">
                <VerticalStackLayout Spacing="18">
                    <Image Source="panaderia_mary_logo.png"
                           HeightRequest="110"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />
                    <Label Text="Registro de cajera"
                           Style="{StaticResource HeadlineLabel}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Este acceso es solo para personal financiero. Los proveedores son creados por la panificadora y el administrador se configura internamente."
                           Style="{StaticResource SectionSubtitleLabel}"
                           HorizontalTextAlignment="Center" />

                    <VerticalStackLayout Spacing="14">
                        <Entry Placeholder="Nombres" Text="{Binding FirstName}" />
                        <Entry Placeholder="Apellidos" Text="{Binding LastName}" />
                        <Entry Placeholder="Identificacion" Text="{Binding IdentificationNumber}" />
                        <Entry Placeholder="Correo" Keyboard="Email" Text="{Binding Email}" />
                        <Entry Placeholder="Telefono" Keyboard="Telephone" Text="{Binding Phone}" />
                        <Entry Placeholder="Clave" IsPassword="True" Text="{Binding Password}" />
                        <Entry Placeholder="Confirmar clave" IsPassword="True" Text="{Binding ConfirmPassword}" />
                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding AcceptPolicies}" />
                            <Label Text="Acepto el uso de mis datos para acceso, trazabilidad y notificaciones del sistema."
                                   VerticalOptions="Center"
                                   HorizontalOptions="Fill"
                                   LineBreakMode="WordWrap" />
                        </HorizontalStackLayout>
                        <Button Text="Crear cuenta"
                                Style="{StaticResource PrimaryAccentButtonStyle}"
                                Command="{Binding RegisterCommand}" />
                        <Button Text="Volver al ingreso"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BackToLoginCommand}" />
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                        <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
