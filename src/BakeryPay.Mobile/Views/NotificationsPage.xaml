<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BakeryPay.Mobile.Views.NotificationsPage"
             Title="Plataforma de Pagos">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,34" Spacing="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notificaciones" Style="{StaticResource SectionTitleLabel}" />
                        <Label Text="Consulta alertas del sistema y comunica novedades a proveedores."
                               Style="{StaticResource SectionSubtitleLabel}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="+ Crear"
                            Style="{StaticResource PrimaryAccentButtonStyle}"
                            IsVisible="{Binding IsInternalRole}"
                            Command="{Binding OpenCreateModalCommand}" />
                </Grid>

                <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />

                <CollectionView ItemsSource="{Binding Notifications}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardFrame}">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                                            <Label Text="{Binding TypeDisplay}" TextColor="{StaticResource Primary}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding SentAtUtc, StringFormat='{0:dd/MM HH:mm}'}"
                                               TextColor="{StaticResource TextMuted}" />
                                    </Grid>

                                    <Label Text="{Binding Message}" />

                                    <Button Text="Marcar como leida"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            IsVisible="{Binding IsRead, Converter={StaticResource InverseBooleanConverter}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkAsReadCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Grid BackgroundColor="{StaticResource Overlay}"
              IsVisible="{Binding IsCreateModalVisible}"
              Padding="18">
            <Frame Style="{StaticResource ModalCardFrame}"
                   VerticalOptions="Center">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Crear notificacion" FontSize="24" FontAttributes="Bold" />
                            <Label Text="Envia un mensaje manual a un proveedor."
                                   Style="{StaticResource SectionSubtitleLabel}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="X"
                                WidthRequest="42"
                                HeightRequest="42"
                                Padding="0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCreateModalCommand}" />
                    </Grid>

                    <Label Text="Proveedor" FontAttributes="Bold" />
                    <Picker Title="Selecciona un proveedor"
                            ItemsSource="{Binding Providers}"
                            ItemDisplayBinding="{Binding BusinessName}"
                            SelectedItem="{Binding SelectedProvider}" />

                    <Label Text="Titulo" FontAttributes="Bold" />
                    <Entry Placeholder="Nueva actualizacion" Text="{Binding TitleText}" />

                    <Label Text="Mensaje" FontAttributes="Bold" />
                    <Editor Placeholder="Escribe el contenido de la notificacion" Text="{Binding MessageText}" />

                    <Label Text="Tipo" FontAttributes="Bold" />
                    <Picker Title="Selecciona un tipo"
                            ItemsSource="{Binding NotificationTypes}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedType}" />

                    <Label Text="{Binding Message}" TextColor="{StaticResource PrimaryDark}" />
                    <Button Text="Enviar notificacion"
                            Style="{StaticResource PrimaryAccentButtonStyle}"
                            Command="{Binding CreateNotificationCommand}" />
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
